{
  "mcpServers": {
    "mattermost-channel": {
      "command": "node",
      "args": ["--import", "tsx", "/path/to/mattermost-claude-channel/src/index.ts"],
      "env": {
        "MATTERMOST_URL": "https://your-mattermost-server.com",
        "MATTERMOST_TOKEN": "your-bot-token-here",
        "ALLOWED_USERS": "",
        "ADMIN_USERS": "",
        "LOG_LEVEL": "info",
        "LISTEN_CHANNELS": ""
      }
    }
  }
}
